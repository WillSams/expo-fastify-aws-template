{
  "name": "@template/api",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts | pino-pretty --colorize --translateTime 'HH:MM:ss'",
    "build": "esbuild src/server.ts --bundle --minify --platform=node --outfile=dist/server.js",
    "test": "tsc --noEmit && NODE_OPTIONS=--experimental-vm-modules ENV=test jest --maxWorkers=2",
    "test:coverage": "tsc --noEmit && NODE_OPTIONS=--experimental-vm-modules ENV=test jest --coverage",
    "lint": "eslint 'src/**/*.ts' 'specs/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'specs/**/*.ts'",
    "prepare": "husky"
  },
  "imports": {
    "#src/*": "./src/*.ts"
  },
  "dependencies": {
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/cors": "^11.3.0",
    "fastify": "^5.10.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  }
}
